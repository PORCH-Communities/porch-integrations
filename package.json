{
  "name": "porch-integrations",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "node --experimental-strip-types --test src/lib/householding/matching.test.mjs src/lib/givebutter/*.test.mjs src/lib/hubspot/*.test.mjs",
    "givebutter:sample-transactions": "node --env-file=.env scripts/sample-givebutter-transactions.mjs",
    "givebutter:reconcile": "node --experimental-strip-types --env-file=.env scripts/reconcile-givebutter-payloads.mjs",
    "givebutter:historical-dry-run": "node --experimental-strip-types --env-file=.env scripts/historical-dry-run.mjs",
    "household:test-matching": "node --experimental-strip-types --env-file=.env scripts/test-household-matching.mjs",
    "household:analyze-clusters": "node --experimental-strip-types --env-file=.env scripts/analyze-household-clusters.mjs --md docs/household-cluster-analysis.md"
  },
  "dependencies": {
    "@vercel/blob": "^2.4.1",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
